{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DirDetective",
  "version": "0.1.1",
  "identifier": "com.dirdetective.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "",
        "width": 1360,
        "height": 860,
        "minWidth": 1200,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4QTlCNEJBOTdCMEZGQUQKUldTdC83Q1h1clNweUJFMG1xTWZIYW1iMFBEZzZwdUliNTFJY2xuY1RMVm5uV2VJUERTaFEvQjAK",
      "endpoints": [
        "https://github.com/gebilaoman/DirDetective/releases/latest/download/latest.json"
      ]
    }
  }
}
